# ============================================
# AI Financial Auditor — Environment Variables
# Copy to .env and fill in your values
# ============================================

# App
SECRET_KEY=your-secret-key-min-32-chars
SUPER_ADMIN_EMAIL=your-google-email@gmail.com
ENVIRONMENT=development

# Python log level for backend package (DEBUG = full LLM bodies in docker logs).
LOG_LEVEL=INFO

# Dev only: POST /categories/analyze without JWT/cookie (uses SUPER_ADMIN_EMAIL user, or first user).
# Ignored when ENVIRONMENT=production. Never enable in production.
# ALLOW_ANALYZE_WITHOUT_AUTH=true

# Google OAuth2
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# OpenRouter (single LLM + embeddings provider)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_auditor
# Optional: override path to numbered *.sql migrations (default: ./migrations next to repo root).
# MIGRATIONS_DIR=/absolute/path/to/migrations
# Optional: skip automatic migrations + ORM repair on API startup (e.g. some test harnesses).
# SKIP_DB_BOOTSTRAP=1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance_auditor

# Observability (comma-separated options: langsmith, langfuse, or langsmith,langfuse)
OBSERVABILITY_BACKENDS=langsmith,langfuse

# LangSmith
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=ai-financial-auditor
LANGCHAIN_TRACING_V2=true

# Langfuse (self-hosted via Docker Compose)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Local file storage fallback (used when Google Drive creds are absent)
LOCAL_STORAGE_PATH=storage

# Dev-only bypass login (development environment only — ignored in production)
# Set to any password; use with SUPER_ADMIN_EMAIL at POST /auth/dev-login
DEV_LOGIN_PASSWORD=devpass123

# Frontend (browser must match a CORS origin below when using cookies)
CORS_ALLOW_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
VITE_API_URL=http://localhost:8000
VITE_APP_PORT=3002
# Optional: Docker / Vite (see frontend/vite.config.ts)
# VITE_PROXY_API_TARGET=http://backend:8000
# VITE_HMR_HOST=localhost
# VITE_HMR_CLIENT_PORT=3002
VITE_GOOGLE_CLIENT_ID=
