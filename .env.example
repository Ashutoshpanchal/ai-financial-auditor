# ============================================
# AI Financial Auditor — Environment Variables
# Copy to .env and fill in your values
# ============================================

# App
SECRET_KEY=your-secret-key-min-32-chars
SUPER_ADMIN_EMAIL=your-google-email@gmail.com
ENVIRONMENT=development

# Google OAuth2
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# OpenRouter (single LLM + embeddings provider)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_auditor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance_auditor

# Observability (comma-separated options: langsmith, langfuse, or langsmith,langfuse)
OBSERVABILITY_BACKENDS=langsmith,langfuse

# LangSmith
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=ai-financial-auditor
LANGCHAIN_TRACING_V2=true

# Langfuse (self-hosted via Docker Compose)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Frontend
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
